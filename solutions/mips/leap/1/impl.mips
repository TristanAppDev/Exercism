.globl is_leap_year

is_leap_year:

andi    $v0,$a0,3               
sltiu   $v0,$v0,1               

rem     $t0,$a0,100             
slt     $t0,$zero,$t0           

rem     $t1,$a0,400             
sltiu   $t1,$t1,1               

and     $v0,$v0,$t0             
or      $v0,$v0,$t1             

jr $ra